{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yhzion/claude-plugin-models/blob/main/plugins/gemini/schemas/review-output.schema.json",
  "title": "Gemini Code Review Output",
  "description": "Structured form of /gemini:review output. The companion currently returns markdown; this schema describes the equivalent shape for future consumers that want to parse the review programmatically.",
  "type": "object",
  "required": ["intent", "issues", "looksGood"],
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "description": "One-sentence inferred intent of the change."
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "file", "whyItMatters", "suggestedFix"],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor"]
          },
          "title": { "type": "string" },
          "file": {
            "type": "string",
            "description": "Path optionally followed by ':<lineno>'."
          },
          "whyItMatters": { "type": "string" },
          "suggestedFix": { "type": "string" }
        }
      }
    },
    "looksGood": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-trivial things the change handles correctly."
    }
  }
}
